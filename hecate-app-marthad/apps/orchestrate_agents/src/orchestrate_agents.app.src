{application, orchestrate_agents, [
    {description, "Agent orchestration — manages agent session lifecycles, LLM calls, notation parsing"},
    {vsn, "0.1.0"},
    {registered, []},
    {mod, {orchestrate_agents_app, []}},
    {applications, [
        kernel,
        stdlib,
        crypto,
        reckon_db,
        evoq,
        reckon_evoq
    ]},
    {env, [
        {tier_mapping, #{
            <<"T1">> => <<"claude-sonnet-4-20250514">>,
            <<"T2">> => <<"claude-sonnet-4-20250514">>,
            <<"T3">> => <<"claude-haiku-3-20250514">>
        }}
    ]},
    {modules, []},
    {licenses, ["Apache-2.0"]},
    {links, [{"GitHub", "https://github.com/hecate-social/hecate-daemon"}]}
]}.
